enum FeedPostType {
  AUTO
  MANUAL
}

model FeedPost {
  id               String         @id @default(cuid())
  organizationId   String?
  organization     Organization?  @relation(fields: [organizationId], references: [id])
  communityPageId  String?
  communityPage    CommunityPage? @relation(fields: [communityPageId], references: [id])
  authorUserId     String?
  type             FeedPostType   @default(MANUAL)
  sourceModule     String?
  sourceId         String?
  title            String?
  description      String?
  coverUrl         String?
  images           Json?
  videoUrl         String?
  pdfUrl           String?
  externalLink     String?
  categoryId       String?
  category         FeedCategory?  @relation(fields: [categoryId], references: [id])
  visibilityConfig Json?
  startAt          DateTime?
  endAt            DateTime?
  isActive         Boolean        @default(true)
  isPinned         Boolean        @default(false)
  viewCount        Int            @default(0)
  shareCount       Int            @default(0)
  bookmarkCount    Int            @default(0)
  clickCount       Int            @default(0)
  createdAt        DateTime       @default(now())
  deletedAt        DateTime?

  poll Poll?
  saves FeedPostSave[]

  @@index([organizationId, isActive])
  @@map("feed_posts")
}

model FeedPostSave {
  id         String   @id @default(cuid())
  feedPostId String
  feedPost   FeedPost @relation(fields: [feedPostId], references: [id])
  memberId   String
  member     Member   @relation(fields: [memberId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([feedPostId, memberId])
  @@map("feed_post_saves")
}

model Poll {
  id            String    @id @default(cuid())
  feedPostId    String    @unique
  feedPost      FeedPost  @relation(fields: [feedPostId], references: [id])
  question      String
  options       Json // string[]
  allowMultiple Boolean   @default(false)
  endsAt        DateTime?
  createdAt     DateTime  @default(now())

  votes PollVote[]

  @@map("polls")
}

model PollVote {
  id          String   @id @default(cuid())
  pollId      String
  poll        Poll     @relation(fields: [pollId], references: [id])
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id])
  optionIndex Int
  createdAt   DateTime @default(now())

  @@unique([pollId, memberId])
  @@map("poll_votes")
}

enum AdSlot {
  TOP_BANNER
  IN_FEED
}

model Ad {
  id           String   @id @default(cuid())
  bannerUrl    String
  targetLink   String?
  slot         AdSlot
  targeting    Json? // { all: bool, cities: [], states: [], countries: [] }
  startAt      DateTime
  endAt        DateTime
  isActive     Boolean  @default(true)
  pricingModel String   @default("FLAT") // FLAT, CPC, CPM
  priceRate    Float    @default(0)
  totalCost    Float    @default(0)
  viewCount    Int      @default(0)
  clickCount   Int      @default(0)
  createdById  String?
  createdAt    DateTime @default(now())

  @@map("ads")
}

model Offer {
  id               String         @id @default(cuid())
  publicId         String         @unique
  companyName      String
  companyLogoUrl   String?
  bannerUrl        String?
  title            String
  description      String?
  categoryId       String?
  category         OfferCategory? @relation(fields: [categoryId], references: [id])
  startAt          DateTime
  endAt            DateTime
  contact          Json?
  links            Json? // { whatsapp, website, maps }
  visibilityConfig Json?
  viewCount        Int            @default(0)
  clickCount       Int            @default(0)
  shareCount       Int            @default(0)
  createdById      String?
  createdAt        DateTime       @default(now())
  deletedAt        DateTime?

  saves OfferSave[]

  @@index([startAt, endAt])
  @@map("offers")
}

model OfferSave {
  id        String   @id @default(cuid())
  offerId   String
  offer     Offer    @relation(fields: [offerId], references: [id])
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  createdAt DateTime @default(now())

  @@unique([offerId, memberId])
  @@map("offer_saves")
}

model News {
  id             String        @id @default(cuid())
  publicId       String        @unique
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  title          String
  description    String?
  coverUrl       String?
  bottomImageUrl String?
  links          Json?
  categoryId     String?
  category       NewsCategory? @relation(fields: [categoryId], references: [id])
  publishedAt    DateTime      @default(now())
  archivedAt     DateTime?
  isArchived     Boolean       @default(false)
  createdById    String?
  createdAt      DateTime      @default(now())
  deletedAt      DateTime?

  bookmarks NewsBookmark[]

  @@index([isArchived, publishedAt])
  @@map("news")
}

model NewsBookmark {
  id        String   @id @default(cuid())
  newsId    String
  news      News     @relation(fields: [newsId], references: [id])
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id])
  createdAt DateTime @default(now())

  @@unique([newsId, memberId])
  @@map("news_bookmarks")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRED
  SUSPENDED
}

model CommunityPage {
  id                    String                 @id @default(cuid())
  publicId              String                 @unique
  name                  String
  logoUrl               String?
  bannerUrl             String?
  about                 String?
  categoryId            String?
  category              CommunityPageCategory? @relation(fields: [categoryId], references: [id])
  contacts              Json?
  socialLinks           Json?
  visibilityConfig      Json?
  joinApprovalMode      String                 @default("MANUAL") // AUTO | MANUAL
  subscriptionPlan      String?
  subscriptionStatus    SubscriptionStatus     @default(ACTIVE)
  subscriptionExpiresAt DateTime?
  createdById           String?
  createdAt             DateTime               @default(now())
  deletedAt             DateTime?

