}

/// User-submitted feedback/suggestions from the mobile app
model UserFeedback {
  id             String       @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  userId         String?
  user           User?        @relation(fields: [userId], references: [id])
  userName       String?
  category       String       @default("Application") // Application | Dharamshala Booking | Events | etc.
  comment        String
  status         String       @default("PENDING") // PENDING | RESOLVED | DISMISSED
  resolvedAt     DateTime?
  resolvedById   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@map("user_feedback")
}

/// User-flagged incorrect information reports (temple/monk info corrections)
model IncorrectReport {
  id             String       @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  reporterId     String?
  reporter       User?        @relation("IncorrectReportReporter", fields: [reporterId], references: [id])
  reporterName   String?
  entityType     String       // TEMPLE | MONK | DHARAMSHALA | JAIN_CENTER | MEMBER
  entityId       String?
  entityName     String?
  flaggedField   String       // Which field is incorrect
  currentValue   String?      // The wrong value
  correctedValue String       // What it should be
  status         String       @default("PENDING") // PENDING | VERIFIED | REJECTED | CORRECTED
  reviewNote     String?
  reviewedAt     DateTime?
  reviewedById   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@map("incorrect_reports")
}

// =============================================================================
// SUPER ADMIN EXTENSIONS — Banners, HomeSection, SubscriptionPlan, ManualTracking
// =============================================================================

/// Promotional banners shown on the mobile app home screen
model AppBanner {
  id          String    @id @default(cuid())
  title       String
  imageUrl    String
  redirectUrl String?
  displayOrder Int       @default(0)
  isActive    Boolean   @default(true)
  deviceType  String    @default("MOBILE")
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedById String?

  @@map("app_banners")
}

/// Dynamic home screen layout sections for the mobile app
model AppHomeSection {
  id           String    @id @default(cuid())
  name         String
  sectionType  String    @default("Carousel") // Carousel | Grid | List | Horizontal Cards
  displayOrder Int       @default(0)
  isActive     Boolean   @default(true)
  config       Json?     // optional extra config
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  String?

  @@map("app_home_sections")
}

/// Subscription plans available to partner organizations
model SubscriptionPlan {
  id          String    @id @default(cuid())
  name        String
  price       Float     @default(0)
  currency    String    @default("INR")
  duration    String    @default("Monthly") // Monthly | Annual | Lifetime
  features    String    // Comma-separated or plain text description
  isActive    Boolean   @default(true)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  deletedById String?

  @@map("subscription_plans")
}

/// Manual vihar location updates logged by temple admins for monks without GPS
model ManualTrackingEntry {
  id           String    @id @default(cuid())
  monkId       String?
  monk         MonkProfile? @relation(fields: [monkId], references: [id])
  monkPublicId String?   // JFMS-xxx for lookup
  monkName     String    // Denormalized display name
  stationName  String    // Current location / checkpoint name
  notes        String?
  loggedById   String?
  loggedAt     DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  @@index([monkId])
  @@map("manual_tracking_entries")
}
